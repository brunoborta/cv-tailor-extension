{
  "manifest_version": 3,
  "name": "CV Tailor",
  "version": "1.0.0",
  "description": "Tailors your CV to any job posting using AI",
  "permissions": ["storage", "activeTab", "scripting", "tabs", "webNavigation"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "CV Tailor"
  },
  "options_page": "options/options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["cv-preview/index.html", "cv-preview/cover-letter.html", "lib/build/pdf.mjs", "lib/build/pdf.worker.mjs"],
      "matches": ["<all_urls>"]
    }
  ]
}
